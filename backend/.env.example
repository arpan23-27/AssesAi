# Server
# Port the Express server listens on
PORT=3000

# Environment: development | test | production
NODE_ENV=development

# PostgreSQL
# Connection string for the primary database (used at runtime)
DATABASE_URL=postgresql://user:password@localhost:5432/assessai

# Connection string for the test database (used by jest)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/assessai_test

# MongoDB
# Connection string for the MongoDB question store
MONGO_URI=mongodb://localhost:27017/assessai

# Redis
# Connection string for the Redis instance (token blacklist + caching)
REDIS_URL=redis://localhost:6379

# JWT
# Secret used to sign and verify access tokens — use a long random hex string (>= 64 bytes)
JWT_ACCESS_SECRET=

# Lifetime of access tokens (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Groq / AI
# API key for the Groq inference API (used for question generation and explanations)
GROQ_API_KEY=
