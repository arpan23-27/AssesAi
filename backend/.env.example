# Backend-only env reference. For the full stack use the root .env.example.

PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/assessai
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/assessai_test

# Redis (token blacklist + AI response cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# Groq / AI
GROQ_API_KEY=
