# ─────────────────────────────────────────────────────────────────────────────
# AssesAI environment. Copy to .env and fill in the two required secrets below.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL (used by docker-compose to provision the database)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=assessai

# Connection strings for running the backend OUTSIDE docker (npm run dev).
# Inside docker-compose these are overridden to use the service hostnames.
DATABASE_URL=postgresql://postgres:password@localhost:5432/assessai
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/assessai_test
REDIS_URL=redis://localhost:6379

# JWT — REQUIRED. Use a long random hex string (>= 64 bytes), e.g.
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# Groq / AI — REQUIRED for explanations and question generation.
# Get a key at https://console.groq.com
GROQ_API_KEY=

# CORS — comma-separated list of allowed frontend origins. Defaults to the Vite
# dev server. In production set this to your deployed frontend URL, e.g.
#   CLIENT_ORIGIN=https://assesai.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Refresh-cookie SameSite policy (optional). Leave unset: defaults to 'strict'
# in dev and 'none' in production. 'none' is required when the frontend and API
# are on different domains (the default Vercel + Render split); set 'lax'/'strict'
# only if you serve both from the same site.
# COOKIE_SAMESITE=none

# Admin seed (optional). If both are set, the seed step creates/promotes this
# user to admin so the /api/ai/generate endpoint is reachable. Leave blank to
# skip admin seeding.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Frontend build-time variable (consumed by Vite, not the backend). Must include
# the /api suffix. Set this in your frontend host (Vercel/Netlify), not here.
#   VITE_API_URL=https://your-api.onrender.com/api
